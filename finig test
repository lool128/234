-- DÜZELTME #10: UIListLayout temizlik kodu basitleştirildi
local function temizleListe(liste)
    for _, cocuk in ipairs(liste:GetChildren()) do
        if cocuk:IsA("GuiObject") and not cocuk:IsA("UIListLayout") and not cocuk:IsA("UIPadding") then
            cocuk:Destroy()
        end
    end
end

local function oyuncuListesiGuncelle(aramaMetni)
    aramaMetni = aramaMetni or ""
    aramaMetni = string.lower(aramaMetni)

    temizleListe(PlayerList)

    local oyuncuSayisi = 0
    for _, oyuncu in ipairs(Players:GetPlayers()) do
        if oyuncu ~= LocalPlayer then
            local oyuncuAdi = string.lower(oyuncu.Name)
            local gosterimAdi = string.lower(oyuncu.DisplayName)

            if aramaMetni == "" or string.find(oyuncuAdi, aramaMetni) or string.find(gosterimAdi, aramaMetni) then
                oyuncuButonuOlustur(oyuncu, PlayerList, false)
                oyuncuSayisi = oyuncuSayisi + 1
            end
        end
    end

    PlayerList.CanvasSize = UDim2.new(0, 0, 0, oyuncuSayisi * 56)
    StatusText.Text = "✅ Hazır | Oyuncu: " .. tostring(oyuncuSayisi)
end

local function favoriListesiGuncelle()
    temizleListe(FavoriList)

    if #Veriler.Favoriler == 0 then
