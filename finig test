-- GELİŞMİŞ BYPASS SİSTEMİ v2.1
-- ============================================================
local BypassManager = {
    Hooks = {},
    FlagFunction = nil,
    TerminateFunction = nil,
    IsVerbose = true,
    IsActive = false
}

local StatusTracker = {
    DetectionDisabled = false,
    KillBlocked = false,
    DebugInfoIntercepted = false,
    RemoteBlocked = false,
    HeartbeatHooked = false
}

local function safeCall(func, ...)
    local success, result = pcall(func, ...)
    if not success and BypassManager.IsVerbose then
        warn("[Bypass Error]", tostring(result))
    end
    return success, result
end

local function wrapFunction(target, handler)
    return safeCall(function()
        return hookfunction(target, newcclosure(handler))
    end)
end

local function bypassAdonis()
    safeCall(function()
        setthreadidentity(2)
        local collected = getgc(true)

        for _, item in ipairs(collected) do
            if typeof(item) == 'table' then
                local detected = rawget(item, 'Detected')
                local kill = rawget(item, 'Kill')

                if typeof(detected) == 'function' and not BypassManager.FlagFunction then
                    BypassManager.FlagFunction = detected
                    wrapFunction(detected, function(trigger, details)
                        if trigger ~= '_' and BypassManager.IsVerbose then
                            warn('[Adonis] Detection blocked:', tostring(trigger), tostring(details))
                        end
                        return true
                    end)
                    StatusTracker.DetectionDisabled = true
                end

                if typeof(kill) == 'function' and rawget(item, 'Variables') 
                    and rawget(item, 'Process') and not BypassManager.TerminateFunction then
                    BypassManager.TerminateFunction = kill
                    wrapFunction(kill, function(cause)
                        if BypassManager.IsVerbose then
                            warn('[Adonis] Kill blocked:', tostring(cause))
                        end
                        return nil
                    end)
                    StatusTracker.KillBlocked = true
                end
            end
        end
        setthreadidentity(7)
    end)
end

local function bypassRegistryKick()
    safeCall(function()
        local registry = getreg()
        for i, v in pairs(registry) do
            if type(v) == "function" then
                local info = getinfo(v)
                if info and (info.name == "kick" or info.name == "Kick") then
                    hookfunction(info.func, function(...) 
                        warn('[Registry] Kick blocked')
                        return nil 
                    end)
                end
            end
        end
    end)
end

local function bypassDebugInfo()
    safeCall(function()
        local original = getrenv().debug.info
        local hooked = hookfunction(original, newcclosure(function(...)
            local args = {...}
            if BypassManager.FlagFunction and args[1] == BypassManager.FlagFunction then
                warn('[Debug] Info hook blocked detection')
                return coroutine.yield(coroutine.running())
            end
            return hooked(...)
        end))
        StatusTracker.DebugInfoIntercepted = true
    end)
end

local function bypassRemotes()
    safeCall(function()
        local mt = getrawmetatable(game)
        local oldNamecall = mt.__namecall

        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "Kick" or method == "kick" then
                warn('[Remote] Kick blocked via namecall')
                return nil
            end
            if method == "FireServer" or method == "InvokeServer" then
                if BypassManager.IsVerbose then
                    warn('[Remote]', tostring(method), 'called on', tostring(self.Name))
                end
            end
            return oldNamecall(self, ...)
        end)
        setreadonly(mt, true)
        StatusTracker.RemoteBlocked = true
    end)
end

-- DÜZELTME #6: Network ownership bypass optimize edildi (event-based)
local function bypassNetworkOwnership()
    safeCall(function()
        local function setOwnership(char)
            if not char then return end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    pcall(function()
                        part:SetNetworkOwner(nil)
                    end)
                end
            end
        end

        if LocalPlayer.Character then
            task.spawn(function()
                task.wait(1)
                setOwnership(LocalPlayer.Character)
            end)
        end

        LocalPlayer.CharacterAdded:Connect(function(char)
            task.wait(1)
            setOwnership(char)
        end)
    end)
end

local function bypassAntiIdle()
    safeCall(function()
        local VirtualUser = game:GetService("VirtualUser")
        LocalPlayer.Idled:Connect(function()
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
            warn('[Anti-AFK] Idle prevented')
        end)
    end)
end

local function cleanMemory()
    safeCall(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:match("AntiCheat") or obj.Name:match("AC_")) then
                pcall(function()
                    obj:Destroy()
                    warn('[Memory] Anti-cheat object removed:', obj.Name)
                end)
            end
        end
    end)
end

local function activateAllBypasses()
    if BypassManager.IsActive then return end
    BypassManager.IsActive = true

    bypassAdonis()
    bypassRegistryKick()
    bypassDebugInfo()
    bypassRemotes()
    bypassNetworkOwnership()
    bypassAntiIdle()
    cleanMemory()

    print(string.format(
        '[Bypass Status] Detection: %s | Kill: %s | Debug: %s | Remote: %s',
        tostring(StatusTracker.DetectionDisabled),
        tostring(StatusTracker.KillBlocked),
        tostring(StatusTracker.DebugInfoIntercepted),
        tostring(StatusTracker.RemoteBlocked)
    ))
end

