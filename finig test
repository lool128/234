local AktifVurgular = {}

local function vurguKaldir(oyuncu)
    local vurgu = AktifVurgular[oyuncu]
    if not vurgu then return end

    pcall(function()
        if vurgu.connection then 
            vurgu.connection:Disconnect() 
            vurgu.connection = nil
        end
        if vurgu.highlight and vurgu.highlight.Parent then 
            vurgu.highlight:Destroy() 
        end
        if vurgu.billboard and vurgu.billboard.Parent then 
            vurgu.billboard:Destroy() 
        end
    end)

    AktifVurgular[oyuncu] = nil
end

-- DÜZELTME #5: Oyuncu Character yeniden oluşturulduğunda vurgu temizleniyor
local function vurguEkle(oyuncu)
    if not getAllModu() then return end
    if not oyuncu or not oyuncu.Character then return end

    if AktifVurgular[oyuncu] then
        vurguKaldir(oyuncu)
    end

    local char = oyuncu.Character
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local highlight = Instance.new("Highlight")
