local function favoriEkle(oyuncu)
    for _, f in ipairs(Veriler.Favoriler) do
        if f.kullanici == oyuncu.Name then
            return false
        end
    end

    table.insert(Veriler.Favoriler, {
        isim = oyuncu.DisplayName,
        kullanici = oyuncu.Name
    })

    if #Veriler.Favoriler > CONFIG.MaxFavori then
        table.remove(Veriler.Favoriler, 1)
    end

    veriKaydet()
    return true
end

local function favoriKaldir(kullaniciAdi)
    for i, f in ipairs(Veriler.Favoriler) do
        if f.kullanici == kullaniciAdi then
            table.remove(Veriler.Favoriler, i)
            veriKaydet()
            return true
        end
    end
    return false
end

