    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 100, 100)
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = char

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "FlingV13_Mesafe"
    billboard.Size = UDim2.new(0, 120, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = hrp

    local mesafeFrame = Instance.new("Frame")
    mesafeFrame.Size = UDim2.new(1, 0, 1, 0)
    mesafeFrame.BackgroundColor3 = Color3.fromRGB(180, 20, 20)
    mesafeFrame.BackgroundTransparency = 0.2
    mesafeFrame.BorderSizePixel = 0
    mesafeFrame.Parent = billboard

    local mesafeCorner = Instance.new("UICorner")
    mesafeCorner.CornerRadius = UDim.new(0, 8)
    mesafeCorner.Parent = mesafeFrame

    local mesafeLabel = Instance.new("TextLabel")
    mesafeLabel.Size = UDim2.new(1, -4, 1, -4)
    mesafeLabel.Position = UDim2.new(0, 2, 0, 2)
    mesafeLabel.Text = "0m"
    mesafeLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    mesafeLabel.BackgroundTransparency = 1
    mesafeLabel.Font = Enum.Font.GothamBold
    mesafeLabel.TextSize = 14
    mesafeLabel.Parent = mesafeFrame

    local mesafeConnection = RunService.Heartbeat:Connect(function()
        local benimChar = LocalPlayer.Character
        local benimHrp = benimChar and benimChar:FindFirstChild("HumanoidRootPart")
        local hedefHrp = oyuncu.Character and oyuncu.Character:FindFirstChild("HumanoidRootPart")

        if benimHrp and hedefHrp then
            local uzaklik = (benimHrp.Position - hedefHrp.Position).Magnitude
            mesafeLabel.Text = string.format("%.1fm", uzaklik)
        else
            mesafeLabel.Text = "?"
        end
    end)

    AktifVurgular[oyuncu] = {
        highlight = highlight,
        billboard = billboard,
        connection = mesafeConnection
    }

    -- Character yeniden oluşturulduğunda vurguyu temizle
    local charConnection
    charConnection = oyuncu.CharacterAdded:Connect(function()
        vurguKaldir(oyuncu)
        if charConnection then
            charConnection:Disconnect()
        end
    end)

    task.delay(CONFIG.VurguSuresi, function()
        vurguKaldir(oyuncu)
        if charConnection then
            charConnection:Disconnect()
        end
    end)
end

