local ToggleStates = {
    AntiFling = true,
    Konum = true,
    Hizli = false,
    AllModu = true,
    Bypass = false
}

local ToggleButtons = {}

local function createToggle(parent, text, stateKey, colorActive, colorInactive)
    local section = Instance.new("Frame")
    section.Size = UDim2.new(1, 0, 0, 50)
    section.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    section.BorderSizePixel = 0
    section.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = section

    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0.9, 0, 0, 38)
    toggle.Position = UDim2.new(0.05, 0, 0, 6)
    toggle.Text = text .. (ToggleStates[stateKey] and ": AÇIK" or ": KAPALI")
    toggle.BackgroundColor3 = ToggleStates[stateKey] and colorActive or colorInactive
    toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 13
    toggle.Parent = section
    addNeonButtonEffect(toggle)

    local tCorner = Instance.new("UICorner")
    tCorner.CornerRadius = UDim.new(0, 10)
    tCorner.Parent = toggle

    ToggleButtons[stateKey] = toggle

    toggle.MouseButton1Click:Connect(function()
        ToggleStates[stateKey] = not ToggleStates[stateKey]
        toggle.Text = text .. (ToggleStates[stateKey] and ": AÇIK" or ": KAPALI")
        toggle.BackgroundColor3 = ToggleStates[stateKey] and colorActive or colorInactive
        sesCal(SesKutuphanesi.Tik, 0.2)

        -- Bypass özel işlem
        if stateKey == "Bypass" and ToggleStates.Bypass then
            activateAllBypasses()
            sesCal(SesKutuphanesi.Uyari, 0.3)
            StarterGui:SetCore("SendNotification", {
                Title = "Bypass",
                Text = "Tüm bypass sistemleri aktif!",
                Duration = 3
            })
        end
    end)

    return toggle
end

