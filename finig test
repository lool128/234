-- DÜZELTME #9: Motor6D ve Weld kontrolü eklendi
local function antiRagdoll(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.PlatformStand = false
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("JointInstance") or v:IsA("Motor6D") or v:IsA("Weld") then
                pcall(function() v.Enabled = true end)
            end
        end
    end
end

local function setCollision(char, durum)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = durum
        end
    end
end

-- DÜZELTME #8: Fling sırasında hedef çıkarsa güvenli çıkış
local function flingHedef(hedefOyuncu, allModu)
    allModu = allModu or false

    if not hedefOyuncu or not hedefOyuncu.Character then
        return false, "Hedef oyuncu bulunamadi"
    end

    local char = LocalPlayer.Character
    if not char then
        return false, "Karakter bulunamadi"
    end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    local tChar = hedefOyuncu.Character
    local tHrp = tChar and tChar:FindFirstChild("HumanoidRootPart")

    if not hrp or not hum then
        return false, "Karakter parcalari eksik"
    end

    if not tHrp then
        return false, "Hedef karakteri eksik"
    end

    if getKonum() then
        eskiKonum = hrp.CFrame
    end

    Veriler.Istatistikler.ToplamFling = Veriler.Istatistikler.ToplamFling + 1
    Veriler.Istatistikler.SonFling = hedefOyuncu.DisplayName

    table.insert(Veriler.Gecmis, 1, {
        isim = hedefOyuncu.DisplayName,
        kullanici = hedefOyuncu.Name,
        zaman = os.date("%H:%M:%S"),
        tarih = os.date("%d.%m.%Y")
    })
    if #Veriler.Gecmis > CONFIG.MaxGecmis then
        table.remove(Veriler.Gecmis)
    end
    veriKaydet()

    if allModu and getAllModu() then
        vurguEkle(hedefOyuncu)
    end

    antiRagdoll(char)

    if getBypass() then
        pcall(function()
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part:SetNetworkOwner(nil)
                end
            end
        end)
    end

    local noclipConnection = nil
    if getAntiFling() then
        noclipConnection = RunService.Stepped:Connect(function()
            setCollision(char, false)
        end)
    end

    hum:ChangeState(Enum.HumanoidStateType.Physics)
    hum.PlatformStand = true

    local bAV = Instance.new("BodyAngularVelocity")
    bAV.Name = "FlingV13_Force"
    bAV.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bAV.AngularVelocity = Vector3.new(0, flingGucu, 0)
    bAV.Parent = hrp

    if getHizli() then
        bAV.AngularVelocity = Vector3.new(0, flingGucu * 1.5, 0)
    end

    local baslangicZaman = tick()
    local followConnection
    local flingBasarili = false

    followConnection = RunService.Heartbeat:Connect(function()
        if kapali then
            if followConnection then followConnection:Disconnect() end
            return
        end

        -- DÜZELTME #8: Hedef oyuncu sunucudan çıktı mı kontrolü
        if not hedefOyuncu.Parent then
            if followConnection then
                followConnection:Disconnect()
                followConnection = nil
            end
            return
        end

        local gecenSure = tick() - baslangicZaman
        local maxSure = getHizli() and CONFIG.FlingSuresi * 0.6 or CONFIG.FlingSuresi

        if gecenSure > maxSure or not tHrp or not tHrp.Parent then
            if followConnection then
                followConnection:Disconnect()
                followConnection = nil
            end
            return
        end

        pcall(function()
            if hrp and tHrp and hrp.Parent and tHrp.Parent then
                local offset = CFrame.new(0, -CONFIG.TakipMesafesi, 0)
                hrp.CFrame = tHrp.CFrame * offset
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.RotVelocity = Vector3.new(0, flingGucu, 0)
                flingBasarili = true
            end
        end)
    end)

    local beklemeSuresi = getHizli() and CONFIG.FlingSuresi * 0.6 or CONFIG.FlingSuresi
    task.wait(beklemeSuresi + 0.1)

    pcall(function()
        if bAV then bAV:Destroy() end
    end)

    if followConnection then
        followConnection:Disconnect()
        followConnection = nil
    end

    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end

    pcall(function()
        if hrp and hrp.Parent then
            -- DÜZELTME #3: eskiKonum nil kontrolü
            if eskiKonum ~= nil and getKonum() then
                hrp.CFrame = eskiKonum
            end
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.RotVelocity = Vector3.new(0, 0, 0)
        end
        antiRagdoll(char)
    end)

    task.wait(0.1)
    setCollision(char, true)

    if flingBasarili then
        Veriler.Istatistikler.BasariliFling = Veriler.Istatistikler.BasariliFling + 1
        return true, "Basarili"
    else
        return false, "Fling basarisiz"
    end
end

