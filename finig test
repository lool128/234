                        effect.ImageTransparency = i
                        task.wait(CONFIG.GlowHiz)
                    end
                    for i = 0.9, 0.6, -0.01 do
                        if kapali then break end
                        effect.ImageTransparency = i
                        task.wait(CONFIG.GlowHiz)
                    end
                end
            end
        end
    end
end)

