local allCalisiyor = false

local function allFlingBaslat()
    if allCalisiyor then return end
    if not getAllModu() then
        StarterGui:SetCore("SendNotification", {
            Title = "ALL MODU",
            Text = "ALL modu ayarlardan kapalı!",
            Duration = 3
        })
        return
    end

    allCalisiyor = true
    AllButton.Text = "🌪️ ALL ÇALIŞIYOR..."
    AllButton.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    AllProgress.Visible = true
    sesCal(SesKutuphanesi.AllStart, 0.5)

    local hedefler = {}
    for _, oyuncu in ipairs(Players:GetPlayers()) do
        if oyuncu ~= LocalPlayer then
            table.insert(hedefler, oyuncu)
        end
    end

    local toplam = #hedefler
    local basarili = 0

    if toplam == 0 then
        AllProgress.Visible = false
        AllButton.Text = "🌪️ ALL - TÜM OYUNCULARA FLING"
        AllButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
        allCalisiyor = false
        StarterGui:SetCore("SendNotification", {
            Title = "ALL Modu",
            Text = "Sunucuda başka oyuncu yok!",
            Duration = 3
        })
        return
    end

    for i, oyuncu in ipairs(hedefler) do
        if kapali then break end

        -- DÜZELTME #4: Tween animasyonlu progress
        local progress = i / toplam
        local tween = TweenService:Create(AllProgress, TweenInfo.new(0.3), {
            Size = UDim2.new(progress, 0, 0, 4)
        })
        tween:Play()

        AllButton.Text = string.format("🌪️ FLING: %s (%d/%d)", oyuncu.DisplayName, i, toplam)

        local ok, msg = pcall(function()
            return flingHedef(oyuncu, true)
        end)

        if ok and msg then basarili = basarili + 1 end

        if i < toplam then
            task.wait(CONFIG.AllModuBekleme)
        end
    end

    -- Progress sıfırla
    local resetTween = TweenService:Create(AllProgress, TweenInfo.new(0.5), {
        Size = UDim2.new(0, 0, 0, 4)
    })
    resetTween:Play()

    task.wait(0.5)
    AllProgress.Visible = false
    AllButton.Text = "🌪️ ALL - TÜM OYUNCULARA FLING"
    AllButton.BackgroundColor3 = Color3.fromRGB(255, 0, 100)
    allCalisiyor = false

    sesCal(SesKutuphanesi.AllDone, 0.5)
    StarterGui:SetCore("SendNotification", {
        Title = "ALL Tamamlandı",
        Text = string.format("%d/%d oyuncuya fling atıldı!", basarili, toplam),
        Duration = 4
    })
end

AllButton.MouseButton1Click:Connect(function()
    if allCalisiyor then return end
    task.spawn(allFlingBaslat)
end)

