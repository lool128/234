-- YARDIMCI FONKSİYONLAR
-- ════════════════════════════════════════════════════
local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color     = color or Color3.fromRGB(50, 50, 80)
    s.Thickness = thickness or 1
    s.Parent    = parent
end

local function padding(parent, px, py)
    local p  = Instance.new("UIPadding")
    local ux = UDim.new(0, px)
    local uy = UDim.new(0, py or px)
    p.PaddingLeft   = ux
    p.PaddingRight  = ux
    p.PaddingTop    = uy
    p.PaddingBottom = uy
    p.Parent = parent
end

local function label(parent, props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Font           = props.font  or Enum.Font.Gotham
    l.TextSize       = props.size  or 12
    l.TextColor3     = props.color or C.TEXT
    l.Text           = props.text  or ""
    l.TextXAlignment = props.align or Enum.TextXAlignment.Left
    l.TextTruncate   = props.wrap and Enum.TextTruncate.None or Enum.TextTruncate.AtEnd
    l.TextWrapped    = props.wrap  or false
    l.Size           = props.sz    or UDim2.new(1, 0, 0, 16)
    l.Position       = props.pos   or UDim2.new(0, 0, 0, 0)
    l.Parent         = parent
    return l
end

local function button(parent, props)
    local b = Instance.new("TextButton")
    b.BackgroundColor3 = props.bg    or C.BG3
    b.BorderSizePixel  = 0
    b.Text             = props.text  or ""
    b.TextColor3       = props.color or C.PURPLE
    b.Font             = props.font  or Enum.Font.GothamBold
    b.TextSize         = props.size  or 12
    b.AutoButtonColor  = false
    b.Size             = props.sz    or UDim2.new(1, 0, 0, 32)
    b.Position         = props.pos   or UDim2.new(0, 0, 0, 0)
    b.Parent           = parent
    corner(b, props.radius or 8)
    local hoverBg  = props.hoverBg or C.PURPLE_DK
    local normalBg = props.bg      or C.BG3
    b.MouseEnter:Connect(function() b.BackgroundColor3 = hoverBg  end)
    b.MouseLeave:Connect(function() b.BackgroundColor3 = normalBg end)
    return b
end

local function badge(parent, txt, bg, fg, xOff, yOff)
    local f = Instance.new("Frame")
    f.Size             = UDim2.new(0, 56, 0, 18)
    f.Position         = UDim2.new(1, xOff or -64, 0, yOff or 6)
    f.BackgroundColor3 = bg or C.BG3
    f.BorderSizePixel  = 0
    f.Parent           = parent
    corner(f, 6)
    local l = Instance.new("TextLabel")
    l.Size             = UDim2.new(1, 0, 1, 0)
    l.BackgroundTransparency = 1
    l.Text             = txt
    l.TextColor3       = fg or C.TEXT
    l.Font             = Enum.Font.GothamSemibold
    l.TextSize         = 9
    l.Parent           = f
    return f, l
end

