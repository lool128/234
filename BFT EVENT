-- Otomatik hop toggle
autoBtn.MouseButton1Click:Connect(function()
    autoHopAktif = not autoHopAktif

    if autoHopAktif then
        autoBtn.Text             = "⏱  Otomatik Hop: AÇIK  ●"
        autoBtn.BackgroundColor3 = C.GREEN_DK
        autoBtn.TextColor3       = C.GREEN

        autoHopThread = task.spawn(function()
            local kalan = AUTO_ARALIK
            while autoHopAktif do
                hopDurumLbl.Text       = "⏳ " .. kalan .. " sn sonra atlıyor..."
                hopDurumLbl.TextColor3 = C.GOLD
                task.wait(1)
                kalan = kalan - 1
                if kalan <= 0 then
                    hopDurumLbl.Text = "🔀 Atlıyor!"
                    serverHop()
                    -- Teleport başarısızsa (Studio gibi) sıfırla
                    task.wait(1)
                    kalan        = AUTO_ARALIK
                    hopYapiliyor = false
                end
            end
            hopDurumLbl.Text = ""
        end)
    else
        autoHopAktif = false
        autoBtn.Text             = "⏱  Otomatik Hop: KAPALI"
        autoBtn.BackgroundColor3 = C.BG2
        autoBtn.TextColor3       = C.MUTED
        hopDurumLbl.Text         = ""
        if autoHopThread then
            task.cancel(autoHopThread)
            autoHopThread = nil
        end
    end
end)

