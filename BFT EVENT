local seciliTag = nil
local tagBtnlar = {}

for _, tag in ipairs(TAG_LIST) do
    local tb = Instance.new("TextButton")
    tb.Size             = UDim2.new(0, 50, 1, 0)
    tb.BackgroundColor3 = C.BG3
    tb.BorderSizePixel  = 0
    tb.Text             = tag.isim
    tb.TextColor3       = C.MUTED
    tb.Font             = Enum.Font.GothamSemibold
    tb.TextSize         = 8
    tb.AutoButtonColor  = false
    tb.Parent           = tagFrame
    corner(tb, 6)

    local capTag = tag
    tb.MouseButton1Click:Connect(function()
        if seciliTag == capTag.isim then
            -- tekrar tıklayınca seçimi kaldır
            seciliTag = nil
            for _, b in ipairs(tagBtnlar) do
                b.btn.BackgroundColor3 = C.BG3
                b.btn.TextColor3       = C.MUTED
            end
        else
            seciliTag = capTag.isim
            for _, b in ipairs(tagBtnlar) do
                if b.tag == capTag.isim then
                    b.btn.BackgroundColor3 = capTag.renk
                    b.btn.TextColor3       = C.WHITE
                else
                    b.btn.BackgroundColor3 = C.BG3
                    b.btn.TextColor3       = C.MUTED
                end
            end
        end
    end)

    table.insert(tagBtnlar, { btn = tb, tag = tag.isim })
end

