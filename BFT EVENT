kaydetBtn.MouseButton1Click:Connect(function()
    if MEVCUT_JOB_ID == "" then
        setStatus("⚠️ Studio'da JobId boş — sadece yayında çalışır", true)
        return
    end
    if not lunaRemote then
        setStatus("⚠️ Server Script bağlı değil!", true)
        return
    end

    local isim = (nameBox.Text ~= "" and nameBox.Text)
        or ("Sunucu · " .. os.date("%H:%M"))

    local not_ = notBox.Text ~= "" and notBox.Text or nil

    local ok, sonuc = pcall(function()
        return lunaRemote:InvokeServer("SAVE_SERVER", {
            jobId   = MEVCUT_JOB_ID,
            placeId = MEVCUT_PLACE_ID,
            isim    = isim,
            not_    = not_,
            etiket  = seciliTag,
            oyuncu  = #Players:GetPlayers(),
        })
    end)

    if not ok then
        setStatus("❌ Hata: " .. tostring(sonuc), true)
    elseif sonuc == "OK" then
        setStatus("✅ Kaydedildi: " .. isim)
        nameBox.Text = ""
        notBox.Text  = ""
        -- Etiketi sıfırla
        seciliTag = nil
        for _, b in ipairs(tagBtnlar) do
            b.btn.BackgroundColor3 = C.BG3
            b.btn.TextColor3       = C.MUTED
        end
    elseif sonuc == "EXISTS" then
        setStatus("⚠️ Bu sunucu zaten kayıtlı!", true)
    else
        setStatus("❌ Yanıt: " .. tostring(sonuc), true)
    end
end)

