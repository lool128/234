-- Tek seferlik hop fonksiyonu
local hopYapiliyor = false
local function serverHop()
    if hopYapiliyor then return end
    hopYapiliyor = true
    hopDurumLbl.Text       = "⏳ Atlıyor..."
    hopDurumLbl.TextColor3 = C.GOLD
    task.wait(0.2)
    local ok, err = pcall(function()
        TeleportService:Teleport(VIP_PLACE, LocalPlayer)
    end)
    if not ok then
        hopDurumLbl.Text       = "❌ " .. tostring(err)
        hopDurumLbl.TextColor3 = C.RED
        setStatus("❌ Hop hatası: " .. tostring(err), true)
        hopYapiliyor = false
    end
    -- Başarılıysa zaten teleport olur, hopYapiliyor önemli değil
end

