local function inputLabel(parent, yPos, txt)
    label(parent, {
        text  = txt,
        size  = 10,
        color = C.MUTED,
        sz    = UDim2.new(1, -6, 0, 14),
        pos   = UDim2.new(0, 3, 0, yPos),
    })
end

local function inputBox(parent, yPos, placeholder)
    local box = Instance.new("TextBox")
    box.Size              = UDim2.new(1, -6, 0, 30)
    box.Position          = UDim2.new(0, 3, 0, yPos)
    box.BackgroundColor3  = C.BG2
    box.BorderSizePixel   = 0
    box.PlaceholderText   = placeholder
    box.PlaceholderColor3 = C.MUTED
    box.Text              = ""
    box.TextColor3        = C.TEXT
    box.Font              = Enum.Font.Gotham
    box.TextSize          = 11
    box.ClearTextOnFocus  = false
    box.Parent            = parent
    corner(box, 8)
    padding(box, 8, 5)
    stroke(box, Color3.fromRGB(40, 35, 75))
    return box
end

