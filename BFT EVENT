local lunaRemote = ReplicatedStorage:FindFirstChild("LunaRemote")

local function listeTemizle()
    for _, c in ipairs(savedScroll:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then
            c:Destroy()
        end
    end
end

local function listeYenile()
    listeTemizle()

    if not lunaRemote then
        label(savedScroll, {
            text  = "⚠️ Server Script aktif değil.\nServerScriptService'e LunaServerManager ekle.",
            size  = 11,
            color = C.RED,
            sz    = UDim2.new(1, -6, 0, 48),
            wrap  = true,
        })
        return
    end

    local ok, kayitlar = pcall(function()
        return lunaRemote:InvokeServer("GET_SERVERS")
    end)

    if not ok or not kayitlar or #kayitlar == 0 then
        label(savedScroll, {
            text  = "Henüz kayıtlı sunucu yok.\n➕ Kaydet sekmesinden ekle.",
            size  = 11,
            color = C.MUTED,
            sz    = UDim2.new(1, -6, 0, 40),
            wrap  = true,
        })
        return
    end

    for _, kayit in ipairs(kayitlar) do
        -- Kart: not varsa daha yüksek
        local kartH = kayit.not_ and kayit.not_ ~= "" and 88 or 72
        local kart = Instance.new("Frame")
        kart.Size             = UDim2.new(1, -6, 0, kartH)
        kart.BackgroundColor3 = C.BG2
        kart.BorderSizePixel  = 0
        kart.Parent           = savedScroll
        corner(kart, 10)
        stroke(kart, Color3.fromRGB(30, 25, 60))

        -- Yeşil nokta
        local dot = Instance.new("Frame")
        dot.Size             = UDim2.new(0, 7, 0, 7)
        dot.Position         = UDim2.new(0, 10, 0, 12)
        dot.BackgroundColor3 = C.GREEN
        dot.BorderSizePixel  = 0
        dot.Parent           = kart
        corner(dot, 10)

        label(kart, {
            text  = kayit.isim or "Sunucu",
            font  = Enum.Font.GothamBold,
            size  = 12,
            color = C.TEXT,
            sz    = UDim2.new(1, -120, 0, 18),
            pos   = UDim2.new(0, 22, 0, 6),
        })
        label(kart, {
            text  = "Place: " .. tostring(kayit.placeId) .. "  |  " .. tostring(kayit.oyuncu or "?") .. " kişi kaydında",
            size  = 9,
            color = C.MUTED,
            sz    = UDim2.new(1, -120, 0, 14),
            pos   = UDim2.new(0, 22, 0, 25),
        })

        local jobStr = tostring(kayit.jobId or "")
        label(kart, {
            text  = "ID: " .. string.sub(jobStr, 1, 20) .. (string.len(jobStr) > 20 and "…" or ""),
            size  = 9,
            color = Color3.fromRGB(70, 70, 100),
            sz    = UDim2.new(1, -120, 0, 12),
            pos   = UDim2.new(0, 22, 0, 40),
        })

        -- Not varsa göster
        if kayit.not_ and kayit.not_ ~= "" then
            local notFrame = Instance.new("Frame")
            notFrame.Size             = UDim2.new(1, -24, 0, 18)
            notFrame.Position         = UDim2.new(0, 12, 0, 56)
            notFrame.BackgroundColor3 = C.BG3
            notFrame.BorderSizePixel  = 0
            notFrame.Parent           = kart
            corner(notFrame, 5)
            padding(notFrame, 4, 1)
            label(notFrame, {
                text  = "📝 " .. kayit.not_,
                size  = 9,
                color = C.ORANGE,
                sz    = UDim2.new(1, 0, 1, 0),
                wrap  = false,
            })
        end

        -- Oyuncu sayısı badge (kayıt sırasındaki)
        local oyuncuSayi = tostring(kayit.oyuncu or "?")
        local _, oyuncuLbl = badge(kart, "👥 " .. oyuncuSayi, Color3.fromRGB(10, 25, 10), C.GREEN, -120, 6)
        oyuncuLbl.Text = "👥 " .. oyuncuSayi

        local gitBtn = button(kart, {
            text    = "→ Git",
            bg      = C.BG3,
            color   = C.PURPLE,
            hoverBg = C.PURPLE_DK,
            sz      = UDim2.new(0, 50, 0, 26),
            pos     = UDim2.new(1, -108, 1, -34),
            size    = 10,
        })
        local silBtn = button(kart, {
            text    = "🗑",
            bg      = C.RED_DK,
            color   = C.RED,
            hoverBg = Color3.fromRGB(70, 20, 20),
            sz      = UDim2.new(0, 32, 0, 26),
            pos     = UDim2.new(1, -50, 1, -34),
            size    = 11,
        })

        local capKayit = kayit
        gitBtn.MouseButton1Click:Connect(function()
            setStatus("🚀 " .. (capKayit.isim or "Sunucu") .. " → bağlanıyor...")
            task.wait(0.3)
            local ok2, err = pcall(function()
                local opts = Instance.new("TeleportOptions")
                opts.ServerInstanceId = capKayit.jobId
                TeleportService:TeleportAsync(capKayit.placeId, {LocalPlayer}, opts)
            end)
            if not ok2 then setStatus("❌ Hata: " .. tostring(err), true) end
        end)

        silBtn.MouseButton1Click:Connect(function()
            if lunaRemote then
                pcall(function() lunaRemote:InvokeServer("DELETE_SERVER", capKayit.jobId) end)
            end
            setStatus("🗑️ Silindi: " .. (capKayit.isim or "Sunucu"))
            listeYenile()
        end)
    end
end

refreshBtn.MouseButton1Click:Connect(listeYenile)

