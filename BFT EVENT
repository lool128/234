local kaydetBtn = button(kaydPage, {
    text    = "💾  Bu Sunucuyu Kaydet",
    bg      = C.GREEN_DK,
    color   = C.GREEN,
    hoverBg = Color3.fromRGB(15, 90, 35),
    sz      = UDim2.new(1, -6, 0, 40),
