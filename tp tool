-- ════════════════════════════════════════════
--  TELEPORT (tek mavi partikül)
-- ════════════════════════════════════════════
local function spawnParticle(pos)
	local part = Instance.new("Part")
	part.Anchored     = true
	part.CanCollide   = false
	part.Transparency = 1
	part.Size         = Vector3.new(1, 1, 1)
	part.Position     = pos
	part.Parent       = workspace

	local att = Instance.new("Attachment", part)
	local pe  = Instance.new("ParticleEmitter", att)
	pe.Texture   = "rbxassetid://258128463"
	pe.Size      = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 2),
		NumberSequenceKeypoint.new(1, 0)
	})
	pe.Lifetime  = NumberRange.new(0.3, 0.6)
	pe.Rate      = 60
	pe.Speed     = NumberRange.new(8, 15)
	pe.Color     = ColorSequence.new(Color3.fromRGB(0, 150, 255))

	Debris:AddItem(part, 0.8)
end

local function teleportTo(cframe)
	if not cframe then return end
	-- SADECE kalkış noktasında 1 partikül
	spawnParticle(humanoidRootPart.Position)

	humanoidRootPart.CFrame = cframe
end

