	local saveBtn = Instance.new("TextButton")
	saveBtn.Name             = "SaveButton"
	saveBtn.Size             = UDim2.new(1,-20,0,40)
	saveBtn.Position         = UDim2.new(0,10,0,334)
	saveBtn.BackgroundColor3 = Color3.fromRGB(0,145,255)
	saveBtn.BorderSizePixel  = 0
	saveBtn.Text             = "➕  Mevcut Konumu Kaydet"
	saveBtn.TextColor3       = Color3.fromRGB(255,255,255)
	saveBtn.TextSize         = 13
	saveBtn.Font             = Enum.Font.GothamBold
	saveBtn.Parent           = mf
	Instance.new("UICorner", saveBtn).CornerRadius = UDim.new(0,6)

	saveBtn.MouseButton1Click:Connect(function()
		local c, name = 1, "Yer 1"
		while savedWaypoints[name] do c=c+1; name="Yer "..c end
		savedWaypoints[name] = humanoidRootPart.CFrame
		table.insert(waypointOrder, name)
		updateWaypointList()
		infoLbl.Text       = "✅ Kaydedildi: " .. name
		infoLbl.TextColor3 = Color3.fromRGB(100,255,100)
		task.delay(2, function()
			if infoLbl and infoLbl.Parent then
				infoLbl.Text       = "🖱️ Tek=Işınlan  ✏️ Çift=İsim  ☰ Sürükle=Sırala"
				infoLbl.TextColor3 = Color3.fromRGB(100,255,100)
			end
		end)
	end)

	saveBtn.MouseEnter:Connect(function() saveBtn.BackgroundColor3 = Color3.fromRGB(25,165,255) end)
	saveBtn.MouseLeave:Connect(function() saveBtn.BackgroundColor3 = Color3.fromRGB(0,145,255)  end)

	-- 🗑️ Tümünü temizle
	local clearBtn = Instance.new("TextButton")
	clearBtn.Name             = "ClearButton"
	clearBtn.Size             = UDim2.new(1,-20,0,30)
	clearBtn.Position         = UDim2.new(0,10,0,380)
	clearBtn.BackgroundColor3 = Color3.fromRGB(85,85,108)
	clearBtn.BorderSizePixel  = 0
	clearBtn.Text             = "🗑️  Tüm Waypointleri Temizle"
	clearBtn.TextColor3       = Color3.fromRGB(255,255,255)
	clearBtn.TextSize         = 11
	clearBtn.Font             = Enum.Font.GothamBold
	clearBtn.Parent           = mf
	Instance.new("UICorner", clearBtn).CornerRadius = UDim.new(0,6)

	clearBtn.MouseButton1Click:Connect(function()
		savedWaypoints = {}
		waypointOrder  = {}
		updateWaypointList()
		infoLbl.Text       = "🗑️ Tüm waypointler temizlendi"
		infoLbl.TextColor3 = Color3.fromRGB(255,150,100)
	end)

	clearBtn.MouseEnter:Connect(function() clearBtn.BackgroundColor3 = Color3.fromRGB(108,108,135) end)
	clearBtn.MouseLeave:Connect(function() clearBtn.BackgroundColor3 = Color3.fromRGB(85,85,108)   end)

	-- ════ ANA ÇERÇEVE SÜRÜKLEME ════
	local frameDragging = false
	local frameDragStart = Vector2.zero
	local framePosStart  = UDim2.new()

	bar.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			frameDragging  = true
			frameDragStart = Vector2.new(inp.Position.X, inp.Position.Y)
			framePosStart  = mf.Position
		end
	end)

	UserInputService.InputChanged:Connect(function(inp)
		if frameDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local d = Vector2.new(inp.Position.X, inp.Position.Y) - frameDragStart
			mf.Position = UDim2.new(
				framePosStart.X.Scale, framePosStart.X.Offset + d.X,
				framePosStart.Y.Scale, framePosStart.Y.Offset + d.Y
			)
		end
	end)

	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			frameDragging = false
		end
	end)

	-- İlk listeyi yükle
	currentGui = sg
	updateWaypointList()

	-- Açılış animasyonu
	mf.Size     = UDim2.new(0,0,0,0)
	mf.Position = UDim2.new(0.5,0,0.5,0)
	TweenService:Create(mf, TweenInfo.new(0.28, Enum.EasingStyle.Back), {
		Size     = UDim2.new(0,320,0,465),
		Position = UDim2.new(0.5,-160,0.5,-232)
	}):Play()
end

-- ════════════════════════════════════════════
--  TOOL EQUIP / UNEQUIP
--  Airwalk: eline alınca AÇILIR, bırakınca KAPANIR
-- ════════════════════════════════════════════
tool.Equipped:Connect(function()
	createGui()
	airwalkStart()       -- OTOMATİK AÇ
end)

tool.Unequipped:Connect(function()
	airwalkEnd()         -- OTOMATİK KAPAT
	if currentGui then
		currentGui:Destroy()
		currentGui = nil
	end
end)

-- Tıkla → mouse konumuna ışınlan
tool.Activated:Connect(function()
	if mouse.Hit then
		teleportTo(CFrame.new(mouse.Hit.Position + Vector3.new(0, 2.5, 0)))
	end
end)

-- E tuşu → airwalk toggle (GUI açıkken)
UserInputService.InputBegan:Connect(function(inp, gp)
	if gp then return end
	if inp.KeyCode ~= Enum.KeyCode.E then return end
	if not currentGui then return end

	if airwalking then airwalkEnd() else airwalkStart() end
end)

-- ════════════════════════════════════════════
--  RESPAWN
-- ════════════════════════════════════════════
player.CharacterAdded:Connect(function(newChar)
	refreshCharacter(newChar)

	-- Eğer airwalk aktifse platformu yeniden oluştur
	if airwalking then
		airwalking = false           -- sıfırla ki airwalkStart çalışsın
		airwalkPlatform = nil
		task.wait(0.3)
		airwalkStart()
	end

	-- Aynı tool'u backpack'e koy (çoğalmadan)
	task.wait(0.1)
	if not player.Backpack:FindFirstChild(tool.Name)
		and tool.Parent ~= newChar then
		tool.Parent = player.Backpack
	end

	-- Yeni humanoid için ölüm tespiti
	connectDeathDetection()
end)

