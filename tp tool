	local dialog = Instance.new("Frame")
	dialog.Name            = "RenameDialog"
	dialog.Size            = UDim2.new(0, 270, 0, 130)
	dialog.Position        = UDim2.new(0.5, -135, 0.5, -65)
	dialog.BackgroundColor3 = Color3.fromRGB(38, 38, 55)
	dialog.BorderSizePixel = 0
