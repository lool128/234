-- ════════════════════════════════════════════
--  AIRWALK
-- ════════════════════════════════════════════
local airwalking     = false
local airwalkPlatform = nil

local function airwalkStart()
	if airwalking then return end
	airwalking = true
	airwalkPlatform = Instance.new("Part")
	airwalkPlatform.Name        = "AirwalkPlatform"
	airwalkPlatform.Anchored    = true
	airwalkPlatform.CanCollide  = true
	airwalkPlatform.Transparency = 1
	airwalkPlatform.Size        = Vector3.new(4, 1, 4)
	airwalkPlatform.Parent      = workspace
	print("✈️ Airwalk AÇIK")
end

local function airwalkEnd()
	if not airwalking then return end
	airwalking = false
	if airwalkPlatform then
		airwalkPlatform:Destroy()
		airwalkPlatform = nil
	end
	print("🚶 Airwalk KAPALI")
end

RunService.Heartbeat:Connect(function()
	if airwalking and airwalkPlatform and airwalkPlatform.Parent then
		local hrp = character and character:FindFirstChild("HumanoidRootPart")
		if hrp then
			airwalkPlatform.CFrame = CFrame.new(hrp.Position + Vector3.new(0, -3.5, 0))
		end
	end
end)

