--// Teleport Fonksiyonu
local function teleportToPosition(cframe)
    if not cframe then return end
    
    -- Efekt
    local part = Instance.new("Part")
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 1
    part.Size = Vector3.new(1, 1, 1)
    part.Position = humanoidRootPart.Position
    part.Parent = workspace
    
    local attachment = Instance.new("Attachment", part)
    local particle = Instance.new("ParticleEmitter", attachment)
    particle.Texture = "rbxassetid://258128463"
    particle.Size = NumberSequence.new(2, 0)
    particle.Lifetime = NumberRange.new(0.3, 0.6)
    particle.Rate = 50
    particle.Speed = NumberRange.new(8, 15)
    particle.Color = ColorSequence.new(Color3.fromRGB(0, 150, 255))
    
    game:GetService("Debris"):AddItem(part, 1)
    
    -- Tween teleport
    local tween = TweenService:Create(humanoidRootPart, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
        CFrame = cframe
    })
    tween:Play()
    
    -- Varış efekti
    delay(0.2, function()
        local endPart = part:Clone()
        endPart.Position = cframe.Position
        endPart.Parent = workspace
        game:GetService("Debris"):AddItem(endPart, 1)
    end)
    
    -- Bildirim
    print("🚀 Işınlanıldı!")
end

--// GUI Oluşturma Fonksiyonu
