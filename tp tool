-- ════════════════════════════════════════════
--  ÖLÜM TESPİTİ
--  Her respawn'da yeniden bağlanır
-- ════════════════════════════════════════════
local function connectDeathDetection()
	humanoid.Died:Connect(function()
		if not deathWaypointEnabled then return end

		local pos  = humanoidRootPart.Position
		local base = string.format("💀 Öldün: %d,%d,%d",
			math.floor(pos.X), math.floor(pos.Y), math.floor(pos.Z))

		local name, c = base, 1
		while savedWaypoints[name] do
			name = base .. "(" .. c .. ")"
			c = c + 1
		end

		savedWaypoints[name] = CFrame.new(pos)
		table.insert(waypointOrder, 1, name)
		print("💀 Ölüm waypoint kaydedildi: " .. name)

		-- GUI açıksa listeyi yenile
		if currentGui then
			updateWaypointList()
		end
	end)
end

