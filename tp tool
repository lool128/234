--[[
	WaypointSystem v3 — Tam Düzeltilmiş
	
	DÜZELTMELER:
	  • Waypointler respawn'da kaybolmuyor (savedWaypoints/waypointOrder script-scope'ta kalıcı)
	  • Tek partikül efekti (sadece mavi, sadece başlangıç noktasında)
	  • Airwalk: tool eline alınınca OTOMATİK AÇILIR, bırakılınca OTOMATİK KAPANIR
	  • Airwalk GUI'de ayrı "kalıcı" toggle YOK — equip/unequip yönetiyor
	  • Yeni gelen ekranda tüm kayıtlı waypointler görünür
	  • Tool çoklanmıyor
	  • E tuşu airwalk toggle (GUI açıkken)
	  • Ölüm waypoint toggle
]]

local Players        = game:GetService("Players")
local TweenService   = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
