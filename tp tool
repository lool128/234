	dialog.Parent          = currentGui
	Instance.new("UICorner", dialog).CornerRadius = UDim.new(0, 10)

	local lbl = Instance.new("TextLabel")
	lbl.Size               = UDim2.new(1,-20,0,28)
	lbl.Position           = UDim2.new(0,10,0,8)
	lbl.BackgroundTransparency = 1
	lbl.Text               = "✏️ İsim Değiştir"
	lbl.TextColor3         = Color3.fromRGB(255,255,255)
	lbl.TextSize           = 14
	lbl.Font               = Enum.Font.GothamBold
	lbl.ZIndex             = 201
	lbl.Parent             = dialog

	local tb = Instance.new("TextBox")
	tb.Size               = UDim2.new(1,-20,0,36)
	tb.Position           = UDim2.new(0,10,0,40)
	tb.BackgroundColor3   = Color3.fromRGB(55,55,78)
	tb.BorderSizePixel    = 0
	tb.Text               = oldName
	tb.TextColor3         = Color3.fromRGB(255,255,255)
	tb.TextSize           = 13
	tb.Font               = Enum.Font.Gotham
	tb.ClearTextOnFocus   = false
	tb.ZIndex             = 201
	tb.Parent             = dialog
	Instance.new("UICorner", tb).CornerRadius = UDim.new(0,6)

	local ok = Instance.new("TextButton")
	ok.Size               = UDim2.new(0,110,0,28)
	ok.Position           = UDim2.new(0,10,1,-36)
	ok.BackgroundColor3   = Color3.fromRGB(0,200,100)
	ok.BorderSizePixel    = 0
	ok.Text               = "✓ Kaydet"
	ok.TextColor3         = Color3.fromRGB(255,255,255)
	ok.TextSize           = 12
	ok.Font               = Enum.Font.GothamBold
	ok.ZIndex             = 201
	ok.Parent             = dialog
	Instance.new("UICorner", ok).CornerRadius = UDim.new(0,6)

	local cancel = Instance.new("TextButton")
	cancel.Size           = UDim2.new(0,110,0,28)
	cancel.Position       = UDim2.new(1,-120,1,-36)
	cancel.BackgroundColor3 = Color3.fromRGB(220,60,60)
	cancel.BorderSizePixel = 0
	cancel.Text           = "✕ İptal"
	cancel.TextColor3     = Color3.fromRGB(255,255,255)
	cancel.TextSize       = 12
	cancel.Font           = Enum.Font.GothamBold
	cancel.ZIndex         = 201
	cancel.Parent         = dialog
	Instance.new("UICorner", cancel).CornerRadius = UDim.new(0,6)

	tb:CaptureFocus()

	local function doOk()
		local newName = tb.Text:match("^%s*(.-)%s*$")
		if newName ~= "" then onConfirm(newName) end
		dialog:Destroy()
	end
	ok.MouseButton1Click:Connect(doOk)
	cancel.MouseButton1Click:Connect(function() dialog:Destroy() end)
	tb.FocusLost:Connect(function(enter) if enter then doOk() end end)
end

-- ════════════════════════════════════════════
--  WAYPOINT LİSTESİ GÜNCELLE
-- ════════════════════════════════════════════
updateWaypointList = function()
	if not currentGui then return end
	local mainFrame  = currentGui:FindFirstChild("MainFrame")
	if not mainFrame then return end
	local scrollFrame = mainFrame:FindFirstChild("WaypointList")
	local infoLabel   = mainFrame:FindFirstChild("InfoLabel")
	if not scrollFrame then return end

	-- Eski satırları temizle
	for _, c in ipairs(scrollFrame:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end

	local function isDeathWp(n) return n:sub(1,4) == "💀 Ö" end
	local function baseColor(n)  return isDeathWp(n) and Color3.fromRGB(80,50,50) or Color3.fromRGB(50,50,72) end
	local function hoverColor(n) return isDeathWp(n) and Color3.fromRGB(105,68,68) or Color3.fromRGB(70,70,105) end

	-- Geçerli waypoint listesi
	local list = {}
	for _, name in ipairs(waypointOrder) do
		if savedWaypoints[name] then
			table.insert(list, { name = name, cframe = savedWaypoints[name] })
		end
	end

	for idx, data in ipairs(list) do
		local row = Instance.new("Frame")
		row.Name             = "WPRow_" .. idx
		row.Size             = UDim2.new(1, -8, 0, 42)
		row.BackgroundColor3 = baseColor(data.name)
		row.BorderSizePixel  = 0
		row.LayoutOrder      = idx
		row.Parent           = scrollFrame
		Instance.new("UICorner", row).CornerRadius = UDim.new(0,6)

		-- ☰ sürükleme tutamacı
		local handle = Instance.new("TextLabel")
		handle.Size               = UDim2.new(0,22,1,0)
		handle.Position           = UDim2.new(0,3,0,0)
		handle.BackgroundTransparency = 1
		handle.Text               = "☰"
		handle.TextColor3         = Color3.fromRGB(160,160,160)
		handle.TextSize           = 14
		handle.Parent             = row

		-- İsim butonu
		local namebtn = Instance.new("TextButton")
		namebtn.Size             = UDim2.new(1,-68,1,0)
		namebtn.Position         = UDim2.new(0,26,0,0)
		namebtn.BackgroundTransparency = 1
		namebtn.Text             = "🚀 " .. data.name
		namebtn.TextColor3       = Color3.fromRGB(235,235,235)
		namebtn.TextSize         = 12
		namebtn.Font             = Enum.Font.GothamBold
		namebtn.TextXAlignment   = Enum.TextXAlignment.Left
		namebtn.TextTruncate     = Enum.TextTruncate.AtEnd
		namebtn.Parent           = row

		-- ✏️ düzenle
		local editbtn = Instance.new("TextButton")
		editbtn.Size             = UDim2.new(0,28,0,28)
		editbtn.Position         = UDim2.new(1,-62,0,7)
		editbtn.BackgroundColor3 = Color3.fromRGB(90,140,255)
		editbtn.BorderSizePixel  = 0
		editbtn.Text             = "✏️"
		editbtn.TextSize         = 12
		editbtn.Font             = Enum.Font.GothamBold
		editbtn.Parent           = row
		Instance.new("UICorner", editbtn).CornerRadius = UDim.new(0,4)

		-- × sil
		local delbtn = Instance.new("TextButton")
		delbtn.Size              = UDim2.new(0,28,0,28)
		delbtn.Position          = UDim2.new(1,-30,0,7)
		delbtn.BackgroundColor3  = Color3.fromRGB(220,60,60)
		delbtn.BorderSizePixel   = 0
		delbtn.Text              = "×"
		delbtn.TextColor3        = Color3.fromRGB(255,255,255)
		delbtn.TextSize          = 18
		delbtn.Font              = Enum.Font.GothamBold
		delbtn.Parent            = row
		Instance.new("UICorner", delbtn).CornerRadius = UDim.new(0,4)

		-- Hover
		row.MouseEnter:Connect(function()  row.BackgroundColor3 = hoverColor(data.name) end)
		row.MouseLeave:Connect(function()  row.BackgroundColor3 = baseColor(data.name)  end)

		-- TEK / ÇİFT TIK
		local lastClick = 0
		namebtn.MouseButton1Click:Connect(function()
			local now = tick()
			if (now - lastClick) < 0.35 then
				-- Çift tık → isim değiştir
				showRenameDialog(data.name, function(newName)
					if newName == data.name then return end
					if savedWaypoints[newName] then
						if infoLabel then infoLabel.Text = "❌ Bu isim zaten var!" end
						return
					end
					savedWaypoints[newName] = savedWaypoints[data.name]
					savedWaypoints[data.name] = nil
					for i,n in ipairs(waypointOrder) do
						if n == data.name then waypointOrder[i] = newName; break end
					end
					updateWaypointList()
				end)
			else
				-- Tek tık → ışınlan
				teleportTo(data.cframe + Vector3.new(0, 2.5, 0))
				row.BackgroundColor3 = Color3.fromRGB(0,200,100)
				if infoLabel then
					infoLabel.Text      = "🚀 Işınlanıldı: " .. data.name
					infoLabel.TextColor3 = Color3.fromRGB(0,255,110)
				end
				task.delay(0.5, function()
					if row and row.Parent then
						row.BackgroundColor3 = baseColor(data.name)
					end
					if infoLabel and infoLabel.Parent then
						infoLabel.Text       = "🖱️ Tek=Işınlan  ✏️ Çift=İsim  ☰ Sürükle=Sırala"
						infoLabel.TextColor3 = Color3.fromRGB(100,255,100)
					end
				end)
			end
			lastClick = now
		end)

		-- ✏️ butonu
		editbtn.MouseButton1Click:Connect(function()
			showRenameDialog(data.name, function(newName)
				if newName == data.name then return end
				if savedWaypoints[newName] then
					if infoLabel then infoLabel.Text = "❌ Bu isim zaten var!" end
					return
				end
				savedWaypoints[newName] = savedWaypoints[data.name]
				savedWaypoints[data.name] = nil
				for i,n in ipairs(waypointOrder) do
					if n == data.name then waypointOrder[i] = newName; break end
				end
				updateWaypointList()
			end)
		end)

		-- × sil
		delbtn.MouseButton1Click:Connect(function()
			savedWaypoints[data.name] = nil
			for i,n in ipairs(waypointOrder) do
				if n == data.name then table.remove(waypointOrder,i); break end
			end
			updateWaypointList()
			if infoLabel then
				infoLabel.Text       = "🗑️ Silindi: " .. data.name
				infoLabel.TextColor3 = Color3.fromRGB(255,150,100)
			end
		end)

		-- ☰ SÜRÜKLEME (sıralama)
		local draggingWP = false
		local wpDragY    = 0

		handle.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				draggingWP = true
				wpDragY    = inp.Position.Y
				row.BackgroundColor3 = Color3.fromRGB(100,100,165)
			end
		end)

		UserInputService.InputChanged:Connect(function(inp)
			if draggingWP and inp.UserInputType == Enum.UserInputType.MouseMovement then
				row.Position = UDim2.new(0, 0, 0, inp.Position.Y - wpDragY)
			end
		end)

		UserInputService.InputEnded:Connect(function(inp)
			if draggingWP and inp.UserInputType == Enum.UserInputType.MouseButton1 then
				draggingWP = false
				row.Position = UDim2.new(0,0,0,0)
				row.BackgroundColor3 = baseColor(data.name)

				local absY  = scrollFrame.AbsolutePosition.Y
				local mouseY = UserInputService:GetMouseLocation().Y
				local relY   = mouseY - absY + scrollFrame.CanvasPosition.Y
				local target = math.clamp(math.ceil(relY / 47), 1, #list)
				if target ~= idx then
					table.remove(waypointOrder, idx)
					table.insert(waypointOrder, target, data.name)
				end
				updateWaypointList()
			end
		end)
	end

	-- Canvas boyutunu güncelle
	local lay = scrollFrame:FindFirstChildOfClass("UIListLayout")
	if lay then
		scrollFrame.CanvasSize = UDim2.new(0,0,0, lay.AbsoluteContentSize.Y + 10)
	end
end

